# Database
DATABASE_URL="mysql://pc_hub_user:pc_hub_pass@localhost:3306/pc_hub_dev"

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:4200

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=7

# Cloudinary (optional — required for product image and payment slip uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PromptPay (optional — required for PromptPay QR payment method)
PROMPTPAY_ID=

# Docker Compose only (not needed for Railway/Vercel deployment)
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=pc_hub_user
MYSQL_PASSWORD=change-me-db-password
MYSQL_DATABASE=pc_hub
