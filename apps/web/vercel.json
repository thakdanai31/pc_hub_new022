{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "dist/web/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://pc-hub-1c79.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
